# Supabase
# Supabase プロジェクトダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role key（サーバーサイド専用。クライアントに公開しないこと）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE WORKS Bot通知（未設定の場合は通知をスキップ）
# Developer Console > アプリ > OAuth から取得
LINEWORKS_CLIENT_ID=your-client-id
LINEWORKS_CLIENT_SECRET=your-client-secret
# Developer Console > アプリ > サービスアカウント & 認証鍵 から取得
LINEWORKS_SERVICE_ACCOUNT=your-service-account@your-domain
# 秘密鍵（PEM形式。改行を \n に置換して1行で記述）
LINEWORKS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
# Bot管理 > BotID
LINEWORKS_BOT_ID=your-bot-id
# 通知先チャンネルID（チャンネルURLの末尾の数字）
LINEWORKS_CHANNEL_ID=your-channel-id
